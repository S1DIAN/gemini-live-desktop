{
  "name": "gemini-live-desktop-mvp",
  "version": "0.1.0",
  "description": "Windows-only Electron desktop client for Gemini Live MVP",
  "main": "dist/main/app.js",
  "author": "Codex",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "dev": "node scripts/dev.mjs",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "build": "npm run clean && npm run build:renderer && npm run build:electron",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest run",
    "dist:win": "npm run build && electron-builder --win nsis portable"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@google/genai": "^1.45.0",
    "electron-log": "^5.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "build": {
    "appId": "local.geminilive.desktop.mvp",
    "productName": "Gemini Live Desktop MVP",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "artifacts"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
